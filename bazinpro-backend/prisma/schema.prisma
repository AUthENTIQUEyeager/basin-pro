generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Boutique {
  id                  String              @id @default(uuid())
  nom                 String
  adresse             String?
  telephone           String?
  logoUrl             String?
  abonnementStatut    AbonnementStatut    @default(ACTIF)
  abonnementDebut     DateTime            @default(now())
  abonnementFin       DateTime
  createdAt           DateTime            @default(now())

  utilisateurs        Utilisateur[]
  qualites            Qualite[]
  couleurs            Couleur[]
  tissus              Tissu[]
  clients             Client[]
  ventes              Vente[]
  depenses            Depense[]
  mouvementsStock     MouvementStock[]
  journalActions      JournalAction[]
  syncQueue           SyncQueue[]

  @@map("boutiques")
}

model Utilisateur {
  id                String      @id @default(uuid())
  boutiqueId        String
  nom               String
  prenom            String
  email             String      @unique
  passwordHash      String
  role              Role        @default(CAISSIER)
  actif             Boolean     @default(true)
  derniereConnexion DateTime?
  createdAt         DateTime    @default(now())

  boutique          Boutique    @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  ventes            Vente[]
  depenses          Depense[]
  mouvementsStock   MouvementStock[]
  journalActions    JournalAction[]

  @@map("utilisateurs")
}

model Qualite {
  id          String    @id @default(uuid())
  boutiqueId  String
  nom         String
  createdAt   DateTime  @default(now())

  boutique    Boutique  @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  tissus      Tissu[]

  @@map("qualites")
}

model Couleur {
  id          String    @id @default(uuid())
  boutiqueId  String
  nom         String
  hex         String    @default("#000000")
  createdAt   DateTime  @default(now())

  boutique    Boutique  @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  tissus      Tissu[]

  @@map("couleurs")
}

model Tissu {
  id                  String          @id @default(uuid())
  boutiqueId          String
  code                String          @unique
  qualiteId           String
  couleurId           String
  metrageDisponible   Decimal         @default(0) @db.Decimal(10, 2)
  metrageAlerte       Decimal         @default(5)  @db.Decimal(10, 2)
  prixAchat           Decimal?        @db.Decimal(10, 0)
  prixVente           Decimal         @db.Decimal(10, 0)
  emplacement         String?
  observation         String?
  qrCode              String?
  statut              StatutStock     @default(DISPONIBLE)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  boutique            Boutique        @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  qualite             Qualite         @relation(fields: [qualiteId], references: [id])
  couleur             Couleur         @relation(fields: [couleurId], references: [id])
  lignesVente         LigneVente[]
  mouvementsStock     MouvementStock[]

  @@map("tissus")
}

model Client {
  id              String    @id @default(uuid())
  boutiqueId      String
  nom             String
  prenom          String
  telephone       String?
  totalAchats     Decimal   @default(0) @db.Decimal(12, 0)
  nbAchats        Int       @default(0)
  derniereVisite  DateTime?
  createdAt       DateTime  @default(now())

  boutique        Boutique  @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  ventes          Vente[]

  @@map("clients")
}

model Vente {
  id                String          @id @default(uuid())
  boutiqueId        String
  numero            String          @unique
  caissierIdRef     String
  clientId          String?
  clientNom         String?
  clientPrenom      String?
  clientTelephone   String?
  montantTotal      Decimal         @db.Decimal(12, 0)
  modePaiement      ModePaiement
  statut            StatutVente     @default(VALIDEE)
  motifAnnulation   String?
  synced            Boolean         @default(false)
  createdAt         DateTime        @default(now())

  boutique          Boutique        @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  caissier          Utilisateur     @relation(fields: [caissierIdRef], references: [id])
  client            Client?         @relation(fields: [clientId], references: [id])
  lignes            LigneVente[]

  @@map("ventes")
}

model LigneVente {
  id            String    @id @default(uuid())
  venteId       String
  tissuId       String?
  tissuCode     String
  qualiteNom    String
  couleurNom    String
  metrage       Decimal   @db.Decimal(10, 2)
  prixUnitaire  Decimal   @db.Decimal(10, 0)
  montant       Decimal   @db.Decimal(12, 0)

  vente         Vente     @relation(fields: [venteId], references: [id], onDelete: Cascade)
  tissu         Tissu?    @relation(fields: [tissuId], references: [id])

  @@map("lignes_vente")
}

model Depense {
  id          String    @id @default(uuid())
  boutiqueId  String
  userId      String
  categorie   String
  montant     Decimal   @db.Decimal(12, 0)
  date        DateTime  @db.Date
  observation String?
  synced      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  boutique    Boutique      @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  user        Utilisateur   @relation(fields: [userId], references: [id])

  @@map("depenses")
}

model MouvementStock {
  id          String          @id @default(uuid())
  tissuId     String
  boutiqueId  String
  type        TypeMouvement
  quantite    Decimal         @db.Decimal(10, 2)
  motif       String?
  userId      String
  createdAt   DateTime        @default(now())

  tissu       Tissu           @relation(fields: [tissuId], references: [id], onDelete: Cascade)
  boutique    Boutique        @relation(fields: [boutiqueId], references: [id])
  user        Utilisateur     @relation(fields: [userId], references: [id])

  @@map("mouvements_stock")
}

model JournalAction {
  id          String    @id @default(uuid())
  boutiqueId  String?
  userId      String?
  action      String
  entite      String?
  entiteId    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime  @default(now())

  boutique    Boutique?     @relation(fields: [boutiqueId], references: [id])
  user        Utilisateur?  @relation(fields: [userId], references: [id])

  @@map("journal_actions")
}

model SyncQueue {
  id          String      @id @default(uuid())
  boutiqueId  String
  operation   String
  entite      String
  entiteId    String?
  payload     Json?
  statut      SyncStatut  @default(PENDING)
  tentatives  Int         @default(0)
  erreur      String?
  createdAt   DateTime    @default(now())
  syncedAt    DateTime?

  boutique    Boutique    @relation(fields: [boutiqueId], references: [id])

  @@map("sync_queue")
}

enum Role {
  MANAGER
  CAISSIER
  SUPER_ADMIN
}

enum AbonnementStatut {
  ACTIF
  SUSPENDU
  EXPIRE
}

enum StatutStock {
  DISPONIBLE
  BAS
  EPUISE
}

enum StatutVente {
  VALIDEE
  ANNULEE
  RETOUR
}

enum ModePaiement {
  ESPECES
  ORANGE_MONEY
  WAVE
  MOOV_MONEY
}

enum TypeMouvement {
  ENTREE
  SORTIE
  CORRECTION
}

enum SyncStatut {
  PENDING
  PROCESSING
  DONE
  ERROR
}
